# ===========================================
# Build stage
# ===========================================
FROM maven:3.9.9-eclipse-temurin-21 AS build
WORKDIR /app

COPY pom.xml /app/
COPY src /app/src

RUN mvn clean package -Pprod -DskipTests

# ===========================================
# Runtime stage
# ===========================================
FROM eclipse-temurin:21-jdk-jammy
WORKDIR /app

COPY --from=build /app/target/helpout-backend-*.jar /app/helpout-backend.jar

EXPOSE 8080
ENTRYPOINT ["sh", "-c", "java $JAVA_OPTS -jar helpout-backend.jar"]
